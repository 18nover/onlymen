!.dockerignore
/forgejo/
!templates/forgejo/
!templates/forgejo/**
runner/data/*
!runner/data/.gitkeep
*.db
*.db-shm
*.db-wal
*.log
.env
.env.*
!.env.example
!.env.sample
.envrc
.DS_Store
*.key
*.pem
*.p12
*.pfx
id_rsa
id_ed25519
node_modules/
dist/
tmp/
secrets/
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfplan
*.tfvars
*.tfvars.json
!*.tfvars.example
**/backend.hcl
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
deployment/hetzner-staging/backups/
deployment/hetzner-staging/runner/data/*
!deployment/hetzner-staging/runner/data/.gitkeep
/*production-evidence*.json
deployment/hetzner-staging/release/*production-evidence*.json
!deployment/hetzner-staging/release/production-evidence.example.json
