# Copy this file to a private .env file on the staging host.
# Keep the filled .env out of Git and out of deployment logs.

COMPOSE_PROJECT_NAME=eliza-forgejo-staging

# Images are placeholders until the staging image policy is chosen.
FORGEJO_IMAGE=registry.staging.example.invalid/forgejo/forgejo:replace-me
POSTGRES_IMAGE=postgres:16-alpine
MERGE_STEWARD_IMAGE=registry.staging.example.invalid/eliza/merge-steward:replace-me
FORGEJO_RUNNER_IMAGE=registry.staging.example.invalid/forgejo/runner:replace-me
FORGEJO_RUNNER_DIND_IMAGE=docker:28-dind

# Public URLs are placeholders. Use private DNS or a staging-only hostname.
FORGEJO_DOMAIN=git.staging.example.invalid
FORGEJO_ROOT_URL=https://git.staging.example.invalid/
FORGEJO_SSH_DOMAIN=git.staging.example.invalid
FORGEJO_PUBLIC_SSH_PORT=22

# Bind to loopback by default so a reverse proxy can own public TLS.
FORGEJO_HTTP_BIND=127.0.0.1
FORGEJO_HTTP_PORT=3000
FORGEJO_SSH_BIND=127.0.0.1
FORGEJO_SSH_PORT=2222

FORGEJO_UID=1000
FORGEJO_GID=1000

FORGEJO_RECOVERY_ADMIN_USERNAME=eliza-recovery-admin
FORGEJO_RECOVERY_ADMIN_EMAIL=eliza-recovery-admin@staging.example.invalid
FORGEJO_RECOVERY_ADMIN_PASSWORD=

FORGEJO_DB_NAME=forgejo
FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASSWORD=

# Generate on the staging host. Do not commit real values.
FORGEJO_SECRET_KEY=
FORGEJO_INTERNAL_TOKEN=
FORGEJO_OAUTH2_JWT_SECRET=

FORGEJO_ACTIONS_ENABLED=true
FORGEJO_ACTIONS_URL=https://actions.staging.example.invalid
FORGEJO_ACTION_LOG_RETENTION_DAYS=14
FORGEJO_ACTION_ARTIFACT_RETENTION_DAYS=14

# Mail is disabled until SMTP, invite, reset, and notification smoke tests pass.
FORGEJO_MAIL_ENABLED=false
FORGEJO_REGISTER_EMAIL_CONFIRM=false
FORGEJO_MAIL_PROTOCOL=smtps
FORGEJO_SMTP_ADDR=
FORGEJO_SMTP_PORT=465
FORGEJO_MAIL_FROM=
FORGEJO_SMTP_USER=
FORGEJO_SMTP_PASSWORD=

# Optional isolated Forgejo Actions runner pool.
FORGEJO_RUNNER_INSTANCE=https://git.staging.example.invalid/
FORGEJO_RUNNER_NAME=eliza-staging-docker-1
FORGEJO_RUNNER_LABELS=docker:docker://node:24-bookworm,node-24:docker://node:24-bookworm,ubuntu-latest:docker://node:24-bookworm
FORGEJO_RUNNER_REGISTRATION_TOKEN=

# Eliza Cloud / Steward OIDC placeholders.
FORGEJO_OIDC_AUTH_NAME=elizacloud
FORGEJO_OIDC_SCOPES="openid email profile groups"
FORGEJO_OIDC_SKIP_LOCAL_2FA=true
FORGEJO_OAUTH2_ENABLE_AUTO_REGISTRATION=true
FORGEJO_OAUTH2_REGISTER_EMAIL_CONFIRM=false
FORGEJO_OAUTH2_USERNAME=nickname
FORGEJO_OAUTH2_ACCOUNT_LINKING=login
FORGEJO_OIDC_REQUIRED_CLAIM_NAME=tenant
FORGEJO_OIDC_REQUIRED_CLAIM_VALUE=eliza
FORGEJO_OIDC_GROUP_CLAIM_NAME=groups
FORGEJO_OIDC_ADMIN_GROUP=eliza-admins
FORGEJO_OIDC_RESTRICTED_GROUP=eliza-agents
ELIZA_CLOUD_OIDC_ISSUER_URL=https://cloud.staging.example.invalid
ELIZA_CLOUD_OIDC_DISCOVERY_URL=https://cloud.staging.example.invalid/.well-known/openid-configuration
ELIZA_CLOUD_OIDC_JWKS_URL=
ELIZA_CLOUD_FORGEJO_CLIENT_ID=
ELIZA_CLOUD_FORGEJO_CLIENT_SECRET=
ELIZA_CLOUD_STEWARD_AUDIENCE=eliza-merge-steward

FORGEJO_THEMES=forgejo-auto,forgejo-light,forgejo-dark,eliza,eliza-light
FORGEJO_DEFAULT_THEME=eliza

# Encrypted off-site backups. The rclone config and age identity are private;
# only the public age recipients file belongs on the application host.
BACKUP_ROOT=/srv/eliza-hub/shared/backups
BACKUP_OFFSITE_REMOTE=r2:eliza-hub-backups/staging
BACKUP_AGE_RECIPIENTS_FILE=/srv/eliza-hub/shared/age-recipients.txt
RCLONE_CONFIG=/srv/eliza-hub/shared/rclone.conf

# Optional merge steward service. Leave unset until the service image and DB are ready.
MERGE_STEWARD_HTTP_BIND=127.0.0.1
MERGE_STEWARD_HTTP_PORT=8080
MERGE_STEWARD_DEPLOYMENT_MODE=production
MERGE_STEWARD_DATABASE_URL=
MERGE_STEWARD_QUEUE_STORE_PATH=
FORGEJO_STEWARD_USERNAME=eliza-merge-steward
FORGEJO_STEWARD_EMAIL=eliza-merge-steward@staging.example.invalid
FORGEJO_STEWARD_TOKEN=
FORGEJO_WEBHOOK_SECRET=
MERGE_STEWARD_API_AUTH_REQUIRED=true
MERGE_STEWARD_API_TOKEN=
MERGE_STEWARD_METRICS_ENABLED=true
MERGE_STEWARD_METRICS_AUTH_REQUIRED=true
MERGE_STEWARD_OIDC_ENABLED=true
MERGE_STEWARD_OIDC_REQUIRED_ROLES=steward,maintainer
MERGE_STEWARD_OIDC_REQUIRED_GROUPS=eliza-team
MERGE_STEWARD_OIDC_ADMIN_ROLES=steward-admin
MERGE_STEWARD_OIDC_ADMIN_GROUPS=eliza-admins
MERGE_STEWARD_MAX_BODY_BYTES=1048576
MERGE_STEWARD_WEBHOOK_REQUIRE_DELIVERY_ID=true
MERGE_STEWARD_EVENT_GATE_ENABLED=true
MERGE_STEWARD_EVENT_GATE_REPOSITORIES=elizaos/eliza
MERGE_STEWARD_EVENT_GATE_TRUSTED_ACTORS=
MERGE_STEWARD_EVENT_GATE_ALLOWED_KINDS=
MERGE_STEWARD_EVENT_GATE_COMMAND_PREFIXES=/eliza,/steward
MERGE_STEWARD_EVENT_GATE_ALLOW_FORKS=false
MERGE_STEWARD_REQUIRE_AGENT_RUN_RECEIPT=false
MERGE_STEWARD_REQUIRE_VERIFIED_AGENT_RUN_RECEIPT=false
MERGE_STEWARD_AGENT_RUN_RECEIPT_SECRET=
MERGE_STEWARD_REQUIRE_WORK_RESERVATION_FOR_AGENT_PRS=false
MERGE_STEWARD_REQUIRE_WORK_ITEM_FOR_AGENT_PRS=false
MERGE_STEWARD_REQUIRE_AGENT_BRANCH_NAMESPACE=false
MERGE_STEWARD_AGENT_BRANCH_NAMESPACE_PREFIX=agent
MERGE_STEWARD_REQUIRE_AGENT_IDENTITY_REGISTRY=false
MERGE_STEWARD_AGENT_IDENTITY_REGISTRY=eliza-smoke-agent
MERGE_STEWARD_AGENT_RUN_RECEIPT_SECRET_ENV=MERGE_STEWARD_AGENT_RUN_RECEIPT_SECRET
FORGEJO_FEEDBACK_ENABLED=false
FORGEJO_FEEDBACK_DRY_RUN=true
FORGEJO_FEEDBACK_LABELS=true
FORGEJO_FEEDBACK_COMMENTS=true
FORGEJO_ENRICHMENT_ENABLED=false
FORGEJO_PROTECTED_BRANCHES=main,develop
FORGEJO_REQUIRED_CHECKS=
FORGEJO_ENRICHMENT_PAGE_LIMIT=50
FORGEJO_ENRICHMENT_MAX_PAGES=10
MERGE_STEWARD_INTEGRATION_ENABLED=false
MERGE_STEWARD_INTEGRATION_DRY_RUN=true
MERGE_STEWARD_INTEGRATION_EXECUTOR=none
MERGE_STEWARD_INTEGRATION_BATCHING=false
MERGE_STEWARD_INTEGRATION_BRANCH_PREFIX=eliza-queue
MERGE_STEWARD_INTEGRATION_BRANCH_MODE=reset
MERGE_STEWARD_INTEGRATION_ALLOW_EMPTY_CHECKS=false
MERGE_STEWARD_INTEGRATION_REMOTE_URL=
MERGE_STEWARD_INTEGRATION_WORK_DIR=/state/git
MERGE_STEWARD_INTEGRATION_GIT_BINARY=git
MERGE_STEWARD_INTEGRATION_PUSH_BRANCH=false
MERGE_STEWARD_INTEGRATION_MERGE_METHOD=merge
MERGE_STEWARD_INTEGRATION_DELETE_BRANCH_AFTER_MERGE=false
MERGE_STEWARD_INTEGRATION_MERGE_TITLE=
MERGE_STEWARD_INTEGRATION_MERGE_MESSAGE=
MERGE_STEWARD_CHECK_POLL_ATTEMPTS=1
MERGE_STEWARD_CHECK_POLL_INTERVAL_MS=0
MERGE_STEWARD_WORKER_ENABLED=false
MERGE_STEWARD_WORKER_ID=merge-steward-worker
MERGE_STEWARD_WORKER_POLL_INTERVAL_MS=5000
MERGE_STEWARD_WORKER_CONFIRM_LIVE_EXECUTION=false
MERGE_STEWARD_WORKER_MAX_CONSECUTIVE_ERRORS=5
MERGE_STEWARD_WORKER_LEASE_ENABLED=true
MERGE_STEWARD_WORKER_LEASE_ID=merge-queue
MERGE_STEWARD_WORKER_LEASE_TTL_MS=30000
MERGE_STEWARD_WORKER_LEASE_HEARTBEAT_INTERVAL_MS=10000
MERGE_STEWARD_WORKER_STALE_QUEUE_ITEM_MS=120000
